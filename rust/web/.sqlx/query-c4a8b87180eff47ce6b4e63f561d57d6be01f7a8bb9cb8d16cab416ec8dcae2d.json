{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT id, created_at, updated_at, game_id, body, is_public, logged_at\n        FROM game_logs\n        WHERE game_id = $1\n          AND (is_public = true OR id IN (\n              SELECT game_log_id FROM game_log_targets WHERE game_player_id = $2\n          ))\n        ORDER BY logged_at ASC\n        ",
