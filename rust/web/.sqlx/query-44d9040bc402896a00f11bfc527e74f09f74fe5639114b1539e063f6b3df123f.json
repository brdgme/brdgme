  "query": "\n        SELECT u.id, u.created_at, u.updated_at, u.name, u.pref_colors, u.theme, u.is_admin\n        FROM users u\n        JOIN user_emails ue ON u.id = ue.user_id\n        WHERE ue.email = $1\n        ",
