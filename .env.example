# Machine-local dev environment overrides.
# Copy this file to .env and fill in your values. .env is gitignored.
# All variables are optional - defaults are shown in comments.

# OpenAI-compatible inference endpoint. Defaults to local Ollama.
# Any OpenAI-compatible provider works (Ollama, OpenRouter, Groq, etc).
# Ollama:      http://localhost:11434
# OpenRouter:  https://openrouter.ai/api
# Ollama Cloud: https://ollama.com
#LLM_URL=http://localhost:11434

# API key for the inference provider. Leave unset for local Ollama.
#LLM_API_KEY=

# Model to use for bot inference. Defaults to qwen3:4b.
# Local (Ollama):    qwen3:4b, qwen3:8b, llama3.2:3b
# Ollama Cloud:      gemma3:4b, ministral-3:3b
# OpenRouter:        qwen/qwen3.6-plus-preview, google/gemma-3-4b-it
#BOT_MODEL=qwen3:4b

# Reasoning effort for the LLM.
# Supported values vary by model: low, medium, high (all reasoning models),
# none, minimal, xhigh (gpt-5 family). Set to "none" for models that don't
# require reasoning, or omit to not send this field at all, letting the
# provider use its own default.
#REASONING_EFFORT=low

# Extra raw JSON fields to merge into the outgoing LLM request body
# (JSON Merge Patch semantics per RFC 7396 - a null value deletes that
# key). Useful for provider-specific params not otherwise exposed.
# Example for OpenCode Go + deepseek-v4-flash (disables reasoning, and
# removes reasoning_effort since this endpoint 400s if both are present):
#LLM_EXTRA_BODY={"reasoning_effort": null, "thinking": {"type": "disabled"}}

# Set bot=trace to log rendered prompts for troubleshooting/optimisation.
#RUST_LOG=info,bot=trace

# --- infra/ (OpenTofu) - only needed to run `tofu` locally ---

# DigitalOcean API token, used by the digitalocean tofu provider for all
# API calls (VPC, DNS, DOKS, projects). Create in the DO control panel:
# API > Tokens > Generate New Token, with read/write scope.
#DIGITALOCEAN_TOKEN=

# Spaces access key pair, distinct from the API token above. Used by the
# digitalocean provider for Spaces bucket resources, and (as AWS_* aliases,
# exported automatically by devenv) by the S3-compatible tofu state backend.
# Create in the DO control panel: API > Spaces Keys > Generate New Key.
#SPACES_ACCESS_KEY_ID=
#SPACES_SECRET_ACCESS_KEY=

# Resend API key for sending email.
#RESEND_API_KEY=
